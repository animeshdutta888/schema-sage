# Runtime server
PORT=8000

# Generation backend: rules, ollama, or lora
SCHEMASAGE_GENERATOR_BACKEND=rules

# Optional Ollama/Qwen backend
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional LoRA/PEFT backend. Keep adapter files out of Git.
LORA_BASE_MODEL=Qwen/Qwen2.5-Coder-0.5B-Instruct
LORA_ADAPTER_PATH=artifacts/lora/schemasage-qwen-0.5b-adapter
